# ═══════════════════════════════════════════════
# Nova Trader - Environment Configuration
# ═══════════════════════════════════════════════

# ── Financial Data (primary source) ──
FINANCIAL_DATASETS_API_KEY=your-financial-datasets-api-key

# ── LLM Providers (configure at least one) ──
# Anthropic (Claude) — default provider for the demo.
ANTHROPIC_API_KEY=your-anthropic-api-key
OPENAI_API_KEY=your-openai-api-key
DEEPSEEK_API_KEY=your-deepseek-api-key
GROQ_API_KEY=your-groq-api-key
MINIMAX_API_KEY=your-minimax-api-key
XAI_API_KEY=your-xai-api-key
OPENROUTER_API_KEY=your-openrouter-api-key

# ── Default Nova Model ──
# Current demo default (Claude Opus 4.8 via Anthropic):
NOVA_MODEL_PROVIDER=Anthropic
NOVA_MODEL_NAME=claude-opus-4-8
# MiniMax stays available as an alternative provider:
# NOVA_MODEL_PROVIDER=MiniMax
# NOVA_MODEL_NAME=MiniMax-M2.7
# MINIMAX_API_BASE=https://api.minimax.io/v1

# Legacy MODEL_PROVIDER / MODEL_NAME are intentionally not used for Nova defaults.

# ── Azure OpenAI (optional) ──
# AZURE_OPENAI_API_KEY=your-azure-openai-api-key
# AZURE_OPENAI_ENDPOINT=your-azure-openai-endpoint
# AZURE_OPENAI_DEPLOYMENT_NAME=your-azure-openai-deployment-name

# ── Ollama (local LLMs) ──
# OLLAMA_BASE_URL=http://127.0.0.1:11434

# ── Paper Trading (Alpaca — free) ──
# ALPACA_API_KEY=your-alpaca-paper-api-key
# ALPACA_SECRET_KEY=your-alpaca-paper-secret-key
# ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ── Social Sentiment (future) ──
# REDDIT_CLIENT_ID=your-reddit-app-client-id
# REDDIT_CLIENT_SECRET=your-reddit-app-secret
# REDDIT_USER_AGENT=nova-trader/0.1

# ── Web Search ──
# Tavily is preferred for stable demos. Without it, Nova attempts a best-effort
# DuckDuckGo HTML fallback for the Web Research Analyst.
# EXASEARCH_API_KEY=your-exa-api-key
# TAVILY_API_KEY=your-tavily-api-key
# X_BEARER_TOKEN=your-x-bearer-token

# ── SEC EDGAR ──
# SEC asks automated clients to send a descriptive user agent with contact info.
SEC_USER_AGENT=nova-trader/0.1 your-email@example.com

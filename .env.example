# ═══════════════════════════════════════════════
# Nova Trader - Environment Configuration
# ═══════════════════════════════════════════════

# ── Financial Data (primary source) ──
FINANCIAL_DATASETS_API_KEY=your-financial-datasets-api-key

# ── LLM Providers (configure at least one) ──
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key
DEEPSEEK_API_KEY=your-deepseek-api-key
GROQ_API_KEY=your-groq-api-key
GOOGLE_API_KEY=your-google-api-key
XAI_API_KEY=your-xai-api-key
GIGACHAT_API_KEY=your-gigachat-api-key
OPENROUTER_API_KEY=your-openrouter-api-key

# ── Azure OpenAI (optional) ──
# AZURE_OPENAI_API_KEY=your-azure-openai-api-key
# AZURE_OPENAI_ENDPOINT=your-azure-openai-endpoint
# AZURE_OPENAI_DEPLOYMENT_NAME=your-azure-openai-deployment-name

# ── Ollama (local LLMs) ──
# OLLAMA_BASE_URL=http://127.0.0.1:11434

# ── Paper Trading (Alpaca — free) ──
# ALPACA_API_KEY=your-alpaca-paper-api-key
# ALPACA_SECRET_KEY=your-alpaca-paper-secret-key
# ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ── Social Sentiment (future) ──
# REDDIT_CLIENT_ID=your-reddit-app-client-id
# REDDIT_CLIENT_SECRET=your-reddit-app-secret
# REDDIT_USER_AGENT=nova-trader/0.1

# ── Web Search ──
# EXASEARCH_API_KEY=your-exa-api-key
# TAVILY_API_KEY=your-tavily-api-key
# X_BEARER_TOKEN=your-x-bearer-token
